# ---- LLM Provider ---------------------------------------------------------
# "openai" works with any OpenAI-compatible endpoint; "anthropic" uses Claude.
LLM_PROVIDER=openai

# ---- Primary path: SiliconFlow --------------------------------------------
# This is the endpoint that produced the committed examples/sample_run.log.
# Sign up at https://siliconflow.cn/ — the free tier covers the demo run.
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# Any OpenAI-compatible endpoint also works — swap the three vars above.
# Examples:
#   api.openai.com   → OPENAI_BASE_URL=https://api.openai.com/v1    OPENAI_MODEL=gpt-4o-mini
#   Local OMLX/Ollama → OPENAI_BASE_URL=http://127.0.0.1:8080/v1    OPENAI_MODEL=<your-local-model>
#   DeepSeek / Moonshot / 智谱 BigModel 等国内网关同理

# ---- Anthropic (optional, only if LLM_PROVIDER=anthropic) -----------------
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- Workflow tunables ----------------------------------------------------
# Maximum revision rounds before the Verdict terminates as MAX_ROUNDS
MAX_REVISIONS=2

# Stagnation threshold: if the Reviewer's open-issue count fails to decrease
# this many consecutive rounds, the Verdict terminates as STAGNATED.
STAGNATION_THRESHOLD=2

# ---- Logging --------------------------------------------------------------
# Directory for JSONL run traces (gitignored).
LOG_DIR=logs
